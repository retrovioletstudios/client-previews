          <div class="form-group"><label class="form-label">Vehicle Make & Model</label><input class="form-input" type="text" placeholder="e.g. 2019 Toyota Tacoma" id="vehicle"/></div>
          <div class="form-group"><label class="form-label">Location Zip Code</label><input class="form-input" type="text" placeholder="e.g. 78704" id="location"/></div>
          
          <div class="form-group">
            <label class="form-label">Requested Service</label>
            <select class="form-select" id="service">
              <option value="">— Select a service —</option>
              <option>Complex Diagnostic / Engine</option>
              <option>Brake Service (1-Yr Warranty)</option>
              <option>Oil Change (90-Day Warranty)</option>
              <option>Lemon Squad 32-Pt Inspection</option>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Promo Code</label>
            <input class="form-input" type="text" value="AUSTINSBEST" readonly style="color:var(--accent); font-weight:bold; border-color:var(--accent); background:rgba(247,200,92,0.05);"/>
            <p style="font-size:11px; color:var(--silver); margin-top:5px;">10% discount automatically applied.</p>
          </div>

          <button class="btn-primary" style="width:100%; font-size:15px; padding:16px; margin-top: 10px;" onclick="submitForm()">Continue in Wrench &rarr;</button>
          <div class="submit-confirm" id="form-confirm">&#10003; Secure request initiated. Roberto will receive your Wrench scheduling request momentarily.</div>
        </div>
      </div>
    </div>
  </section>
</div>

<footer>
  <div class="footer-logo">AUSTIN'S<span>BEST</span></div>
  <div class="footer-address">Mobile Service &middot; (512) 746-7277 &middot; Servicing Austin & Surrounding Areas</div>
  <div class="footer-areas" style="color: var(--silver); font-size: 11px; margin-top: 10px;">Master Mechanics &middot; Lemon Squad Partners &middot; Wrench Scheduling</div>
</footer>

<script>
  function showPage(name) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
    document.getElementById('page-' + name).classList.add('active');
    document.getElementById('nav-' + name).classList.add('active');
    window.scrollTo(0, 0);
  }
  function submitForm() {
    const fname = document.getElementById('fname').value.trim();
    const service = document.getElementById('service').value;
    if (!fname || !service) { alert('Please provide your name and select a service.'); return; }
    const confirm = document.getElementById('form-confirm');
    confirm.style.display = 'block';
    confirm.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
</body>
</html>
