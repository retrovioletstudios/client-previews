<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    /* Warning Yellow & Asphalt Black Palette */
    --accent: #F8DE22; 
    --accent-dark: #D4B910; 
    --highlight: #FFFFFF;
    --dark: #080616; 
    --dark2: #120F26; 
    --dark3: #1A1635;
    --light: #E8E8E8; --white: #FFFFFF;
    --font-head: 'Bebas Neue', sans-serif;
    --font-body: 'Barlow', sans-serif;
    --font-sub: 'Barlow Condensed', sans-serif;
  }
  body { font-family: var(--font-body); background: var(--dark); color: var(--white); overflow-x: hidden; }

  nav {
    background: rgba(8,6,22,0.97); border-bottom: 3px solid var(--accent);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 56px; position: sticky; top: 0; z-index: 100;
