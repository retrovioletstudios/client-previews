  .nav-logo { font-family: var(--font-head); font-size: 26px; letter-spacing: 2px; color: var(--white); display: flex; align-items: center; gap: 10px; }
  .nav-logo span { color: var(--accent); }
  .nav-loc { font-family: var(--font-sub); font-size: 12px; color: #888; letter-spacing: 1px; text-transform: uppercase; padding-left: 10px; border-left: 1px solid #2A2A2A; }
  .nav-links { display: flex; gap: 1.75rem; }
  .nav-links a { font-family: var(--font-sub); font-size: 14px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--light); text-decoration: none; cursor: pointer; border-bottom: 2px solid transparent; padding-bottom: 2px; transition: color 0.2s; }
  .nav-links a:hover, .nav-links a.active { color: var(--accent); border-color: var(--accent); }
  .nav-cta { background: var(--accent); color: var(--dark); font-family: var(--font-sub); font-weight: 700; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; border: none; padding: 9px 20px; cursor: pointer; transition: background 0.2s; }
  .nav-cta:hover { background: var(--accent-dark); }

  .page { display: none; }
  .page.active { display: block; }

  .hero { position: relative; background: var(--dark); padding: 4rem 2rem 2.5rem; overflow: hidden; display: flex; justify-content: center; }
  .hero-bg-pattern { position: absolute; inset: 0; background-image: repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(248,222,34,0.03) 40px, rgba(248,222,34,0.03) 41px); }
  .hero-accent { position: absolute; right: 0; top: 0; bottom: 0; width: 40%; background: var(--accent); clip-path: polygon(14% 0, 100% 0, 100% 100%, 0% 100%); opacity: 0.07; }
  .hero-content { position: relative; z-index: 2; max-width: 660px; text-align: center; }
  .hero-tag { display: inline-block; background: var(--accent); color: var(--dark); font-family: var(--font-sub); font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 4px 12px; margin-bottom: 1rem; }
  .hero h1 { font-family: var(--font-head); font-size: clamp(52px, 8vw, 88px); line-height: 0.92; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; }
  .hero h1 em { color: var(--accent); font-style: normal; }
  .hero-sub { font-size: 16px; color: #AAA; max-width: 480px; line-height: 1.6; margin-bottom: 1.75rem; margin-left: auto; margin-right: auto; }
  .hero-sub strong { color: var(--white); }
  
  /* Upgraded Mobile Call Button for Emergency Response */
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-bottom: 2rem; }
  .btn-primary { background: var(--accent); color: var(--dark); font-family: var(--font-sub); font-weight: 700; font-size: 16px; letter-spacing: 2px; text-transform: uppercase; border: none; padding: 16px 36px; cursor: pointer; transition: background 0.2s, transform 0.15s; text-decoration: none; display: inline-block;}
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); }
  
  .btn-outline { background: transparent; color: var(--white); font-family: var(--font-sub); font-weight: 700; font-size: 14px; letter-spacing: 2px; text-transform: uppercase; border: 2px solid #444; padding: 14px 28px; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  
  .hero-stats { display: flex; gap: 2.5rem; justify-content: center; padding-top: 1.5rem; border-top: 1px solid #1A1A1A; }
  .hero-stat-num { font-family: var(--font-head); font-size: 38px; color: var(--accent); line-height: 1; }
  .hero-stat-label { font-family: var(--font-sub); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: #777; margin-top: 3px; }

  .marquee-strip { background: var(--accent); padding: 12px 0; overflow: hidden; white-space: nowrap; margin-top: 2rem; }
  .marquee-inner { display: inline-flex; animation: marquee 22s linear infinite; }
  .marquee-item { font-family: var(--font-head); font-size: 20px; letter-spacing: 3px; text-transform: uppercase; padding: 0 1.75rem; color: var(--dark); }
  .marquee-dot { color: var(--dark); opacity: 0.5; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .section { padding: 3.5rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-label { font-family: var(--font-sub); font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
  .section-title { font-family: var(--font-head); font-size: clamp(32px, 5vw, 50px); letter-spacing: 1px; text-transform: uppercase; line-height: 1; margin-bottom: 1.25rem; }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: #1A1A1A; border: 1.5px solid #1A1A1A; margin-top: 2rem; }
  @media (max-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  .service-card { background: var(--dark2); padding: 1.75rem 1.5rem; transition: background 0.2s; position: relative; overflow: hidden; }
  .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover { background: var(--dark3); }
  .service-icon { font-size: 28px; margin-bottom: 0.75rem; }
  .service-name { font-family: var(--font-sub); font-size: 16px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.4rem; }
  .service-desc { font-size: 13px; color: #888; line-height: 1.5; }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 1.25rem; margin-top: 2rem; }
  .why-card { background: var(--dark2); border: 1.5px solid #222; padding: 1.5rem; }
  .why-num { font-family: var(--font-head); font-size: 44px; color: var(--accent); line-height: 1; margin-bottom: 0.25rem; }
  .why-label { font-family: var(--font-sub); font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--white); margin-bottom: 0.4rem; }
  .why-desc { font-size: 13px; color: #777; line-height: 1.5; }

  .services-page-hero { background: var(--dark2); border-bottom: 3px solid var(--accent); padding: 3rem 2rem 2.5rem; text-align: center; }
  .services-big-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.75rem; margin-top: 2.5rem; text-align: left;}
  .service-big-card { background: var(--dark2); border: 1.5px solid #222; padding: 1.75rem; transition: border-color 0.2s, transform 0.2s; position: relative; }
  .service-big-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .service-price { font-family: var(--font-head); font-size: 32px; color: var(--accent); margin-bottom: 0.2rem; }
  .service-price-label { font-size: 12px; color: #666; margin-bottom: 1rem; }
  .service-features { list-style: none; margin: 1rem 0; }
  .service-features li { font-size: 13px; color: #AAA; padding: 6px 0; border-bottom: 1px solid #1A1A1A; display: flex; align-items: center; gap: 8px; }
  .service-features li::before { content: '✓'; color: var(--accent); font-weight: 700; font-size: 12px; }

  /* New Dispatch Areas Formatting */
  .areas-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; justify-content: center;}
  .area-pill { font-family: var(--font-sub); font-size: 14px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--dark); background: var(--accent); padding: 8px 16px; border-radius: 2px;}

  .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3.5rem; margin-top: 2.5rem; align-items: start; text-align: left;}
  .contact-info-block { margin-bottom: 1.75rem; }
  .contact-info-label { font-family: var(--font-sub); font-size: 11px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
  .contact-info-val { font-size: 15px; color: #CCC; line-height: 1.6; }
  .contact-hours { background: var(--dark2); border: 1.5px solid #222; border-left: 4px solid var(--accent); padding: 1.25rem; }
  .hours-row { display: flex; justify-content: space-between; font-size: 13px; color: #AAA; padding: 5px 0; border-bottom: 1px solid #1A1A1A; }
  .hours-row:last-child { border-bottom: none; }
  .hours-open { color: var(--accent); font-weight: 600; }
  
  .form-group { margin-bottom: 1rem; }
  .form-label { display: block; font-family: var(--font-sub); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #888; margin-bottom: 5px; }
  .form-input, .form-select, .form-textarea { width: 100%; background: var(--dark2); border: 1.5px solid #333; color: var(--white); font-family: var(--font-body); font-size: 14px; padding: 11px 13px; outline: none; transition: border-color 0.2s; appearance: none; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); }
  .form-textarea { resize: vertical; min-height: 100px; }
  .form-select option { background: var(--dark2); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .submit-confirm { background: var(--dark2); border: 1.5px solid #2C2; color: #6F6; padding: 0.9rem 1.25rem; font-family: var(--font-sub); font-size: 14px; letter-spacing: 1px; margin-top: 0.75rem; display: none; }

  footer { background: #05040A; border-top: 3px solid var(--accent); padding: 2rem; text-align: center; }
  .footer-logo { font-family: var(--font-head); font-size: 28px; letter-spacing: 3px; margin-bottom: 0.25rem; }
  .footer-logo span { color: var(--accent); }
  .footer-address { font-size: 13px; color: #555; margin-bottom: 0.3rem; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
</style>
</head>
